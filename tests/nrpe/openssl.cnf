[ req ]
distinguished_name = req_distinguished_name
x509_extensions    = v3_ca
prompt             = no

[ req_distinguished_name ]
C = US
ST = California
L = San Francisco
O = MyCompany
OU = MyDept
CN = my-domain.com

# Stamped onto the self-signed root CA when generated with
# `openssl req -x509 -config openssl.cnf ...`. basicConstraints
# CA:TRUE is required, otherwise modern OpenSSL refuses to use
# the certificate as a trust anchor when verifying peer certs
# during the TLS handshake.
[ v3_ca ]
basicConstraints       = critical, CA:TRUE
keyUsage               = critical, digitalSignature, keyCertSign, cRLSign
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid:always, issuer

# Stamped onto the server certificate (passed via
# `openssl x509 -req ... -extfile openssl.cnf -extensions server_cert`).
[ server_cert ]
basicConstraints     = CA:FALSE
keyUsage             = critical, digitalSignature, keyEncipherment
extendedKeyUsage     = serverAuth
subjectAltName       = @server_alt_names
subjectKeyIdentifier = hash

[ server_alt_names ]
DNS.1 = localhost
IP.1  = 127.0.0.1

# Stamped onto the client certificate (passed via
# `openssl x509 -req ... -extfile openssl.cnf -extensions client_cert`).
[ client_cert ]
basicConstraints     = CA:FALSE
keyUsage             = critical, digitalSignature
extendedKeyUsage     = clientAuth
subjectKeyIdentifier = hash
