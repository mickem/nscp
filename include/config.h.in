#pragma once

#include <string>

#include "version.hpp"

#define APPLICATION_NAME "NSClient++"

#if defined(_M_IX86)
#define SZARCH "w32"
#elif defined(_M_X64)
#define SZARCH "x64"
#elif defined(_M_IA64)
#define SZARCH "ia64"
#else
#define SZARCH "unknown"
#endif

#define DEFAULT_SERVICE_NAME "@CONFIG_DEFAULT_SERVICE_NAME@"
#define DEFAULT_SERVICE_DESC "@CONFIG_DEFAULT_SERVICE_DESC@"
#define DEFAULT_SERVICE_DEPS "@CONFIG_DEFAULT_SERVICE_DEPS@"

// displayed name and version
#define SERVICE_NAME APPLICATION_NAME " " CURRENT_SERVICE_VERSION " " SZARCH
#define CURRENT_SERVICE_VERSION STRPRODUCTVER " " STRPRODUCTDATE

#define CRASH_ARCHIVE_FOLDER_KEY "crash-folder"
#define CACHE_FOLDER_KEY "cache-folder"
#define CACHE_FOLDER "${cache-folder}"

#define CRASH_SUBMIT_URL "@CONFIG_CRASH_SUBMIT_URL@"
#define CRASH_ARCHIVE_FOLDER "@CONFIG_CRASH_ARCHIVE_FOLDER@"

#define DEFAULT_CONF_LOCATION "@CONFIG_DEFAULT_CONF_LOCATION@"
#define DEFAULT_CONF_OLD_LOCATION "@CONFIG_DEFAULT_CONF_OLD_LOCATION@"
#define DEFAULT_CONF_REG_LOCATION "@CONFIG_DEFAULT_CONF_REG_LOCATION@"
#define BOOT_CONF_LOCATION "@CONFIG_BOOT_CONF_LOCATION@"
#define DEFAULT_CONF_INI_BASE "@CONFIG_DEFAULT_CONF_INI_BASE@"
#define DEFAULT_CONF_INI_LOCATION "@CONFIG_DEFAULT_CONF_INI_LOCATION@"
#define DEFAULT_LOG_LOCATION "@CONFIG_DEFAULT_LOG_LOCATION@"
#define DEFAULT_CACHE_PATH "@CONFIG_DEFAULT_CACHE_PATH@"
#define MODULE_FOLDER "@CONFIG_MODULE_FOLDER@"
#define WEB_FOLDER "@CONFIG_WEB_FOLDER@"
#define SCRIPTS_FOLDER "@CONFIG_SCRIPTS_FOLDER@"
#define CERT_FOLDER "@CONFIG_CERT_FOLDER@"
#define LOG_FOLDER "@CONFIG_LOG_FOLDER@"
#ifndef WIN32
#define UNIX_SHARED_PATH_FOLDER "@UNIX_SHARED_PATH_FOLDER@"
#define UNIX_DATA_PATH_FOLDER "@UNIX_DATA_PATH_FOLDER@"
// Config root for this build (NSCP_SYSCONFDIR): tracks CMAKE_INSTALL_PREFIX,
// e.g. /etc for --prefix=/usr, /usr/local/etc for --prefix=/usr/local. Backs
// the ${etc} path token. NOT the system CA location - see ca-path.
#define ETC_FOLDER "@CONFIG_ETC_FOLDER@"
#endif

#define NASTY_METACHARS "|`&><'\"\\[]{}" /* This may need to be modified for windows directory seperator */
/* Stricter set, enforced ONLY when a command degrades to the /bin/sh -c (popen)
 * fallback in CheckExternalScripts. The shared NASTY_METACHARS above deliberately
 * permits %, (, ), $ so internal check syntax (e.g. "top-syntax=%(status): %(list)"
 * / "filter=...") keeps working over NRPE/check_nt - those checks never touch a
 * shell. Once a string is handed to a shell, however, those characters are
 * dangerous, so block them on that path only. */
#define SHELL_METACHARS "|`&><'\"\\[]{}$;()*?~!\n\r"

#define MAIN_MODULES_SECTION "/modules"
#define NS_HKEY_ROOT HKEY_LOCAL_MACHINE
#define NS_REG_ROOT L"SOFTWARE\\NSClient++"
